{
  // SuperDeepSeek Worker — Cloudflare Worker + Static Assets
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  "name": "superdeepseek-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "superdeepseek",
      // Replace with the real D1 database id from `wrangler d1 create superdeepseek`
      "database_id": "PLACEHOLDER_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  }
}
